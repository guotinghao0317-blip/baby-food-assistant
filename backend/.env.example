# 数据库配置
DATABASE_URL=postgresql://babyfood:babyfood123@localhost:5432/babyfood_db

# Redis配置
REDIS_URL=redis://localhost:6379/0

# OpenAI API Key（用于LLM和图像生成）
OPENAI_API_KEY=your-openai-api-key-here

# 火山引擎 API Key（用于动态食谱生成）
VOLCENGINE_API_KEY=your-volcengine-api-key-here
VOLCENGINE_BASE_URL=https://aquasearch.volcengineapi.com
VOLCENGINE_MODEL_NAME=doubao-1.5-pro-32k
VOLCENGINE_TIMEOUT=30

# JWT密钥（生产环境请使用强随机字符串）
SECRET_KEY=your-secret-key-change-in-production

# 其他配置
ENVIRONMENT=development
