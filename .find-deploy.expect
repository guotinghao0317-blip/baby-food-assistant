#!/usr/bin/expect

set timeout 60
set password "@qie8023"
set server_ip "170.106.110.237"
set username "ubuntu"

spawn ssh $username@$server_ip

expect {
    "*(yes/no)?*" {
        send "yes\r"
        expect "*password:"
        send "$password\r"
    }
    "*password:" {
        send "$password\r"
    }
}

expect "$username@"

send "find ~/baby-food-assistant -name \"*deploy-production*\"\r"
expect "$username@"

send "exit\r"
interact
