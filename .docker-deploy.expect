#!/usr/bin/expect

set timeout 1200
set password "@qie8023"
set server_ip "170.106.110.237"
set username "ubuntu"

spawn ssh $username@$server_ip

expect {
    "*(yes/no)?*" {
        send "yes\r"
        expect "*password:"
        send "$password\r"
    }
    "*password:" {
        send "$password\r"
    }
}

expect "$username@"

send "cd ~/baby-food-assistant && ls -la\r"
expect "$username@"

# Set environment variables
send "export OPENAI_API_KEY=c27412f1-239d-453f-a0b9-5e5bd296b027\r"
expect "$username@"
send "export SECRET_KEY=58122a33830a7540724586ca76836f1590762c5711d65b5aff7e3df4fd7d8159\r"
expect "$username@"
send "export POSTGRES_USER=babyfood\r"
expect "$username@"
send "export POSTGRES_PASSWORD=babyfood123\r"
expect "$username@"
send "export POSTGRES_DB=babyfood_db\r"
expect "$username@"
send "export ENVIRONMENT=production\r"
expect "$username@"
send "export NEXT_PUBLIC_API_URL=http://170.106.110.237:8000\r"
expect "$username@"

# Now run docker-compose up with the copied deploy-production.yml
send "docker-compose -f deploy-production.yml up -d --build\r"

# Wait for build and deployment (15 minutes)
set timeout 1200
expect "$username@"
set timeout 30

# Show container status
send "docker-compose -f deploy-production.yml ps\r"
expect "$username@"

# Check disk usage
send "df -h\r"
expect "$username@"

# Wait for services to start up
send "sleep 45\r"
expect "$username@"

# Health check
send "echo '--- Backend Health Check ---' && curl -s http://localhost:8000/health\r"
expect "$username@"

# Frontend check
send "echo '--- Frontend Check ---' && curl -s -I http://localhost:3000 | head -12\r"
expect "$username@"

send "exit\r"
interact
