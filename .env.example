# ============================================
# 宝宝辅食助手 - 环境变量配置示例
# 复制此文件为 .env 并填写对应的值
# ============================================

# ============================================
# OpenAI API 配置
# ============================================
# OpenAI API Key（用于LLM和图像生成）
OPENAI_API_KEY=your-openai-api-key-here

# ============================================
# 安全配置
# ============================================
# JWT密钥（生产环境请使用强随机字符串）
# 可以使用命令生成：openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production

# ============================================
# 运行环境
# ============================================
# 环境模式：development 或 production
ENVIRONMENT=development

# ============================================
# 线上部署配置（反向代理/SSL）
# ============================================
# 你的域名（例如：babyfood.example.com）
DOMAIN=your-domain.com

# 前端API地址（线上部署时需要设置为你的域名）
# 例如：https://your-domain.com/api
NEXT_PUBLIC_API_URL=https://your-domain.com/api
